# 프론트엔드 환경 변수 예시. 실제 값은 복사해서 .env 에 작성하세요 (.env 는 커밋하지 않습니다).
#
# 로컬 개발:
#   VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
#
# Cloudflare Tunnel 데모:
#   cloudflared tunnel --url http://localhost:8000 으로 얻은 백엔드 터널 URL을 아래에 넣으세요.
VITE_API_BASE_URL=https://YOUR_BACKEND_TUNNEL.trycloudflare.com/api/v1
